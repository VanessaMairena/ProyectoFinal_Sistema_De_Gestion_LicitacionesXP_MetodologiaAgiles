@model LicitacionDto
@{
    ViewData["Title"] = "Eliminar licitación";
}

<h1>Eliminar licitación</h1>

<div class="alert alert-warning">¿Confirmás que querés eliminar esta licitación?</div>

<dl class="row">
    <dt class="col-sm-2">Código</dt>
    <dd class="col-sm-10">@Model.Codigo</dd>
    <dt class="col-sm-2">Título</dt>
    <dd class="col-sm-10">@Model.Titulo</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>

@model CrearLicitacionRequest
@{
    ViewData["Title"] = "Nueva licitación";
}

<h1>Nueva licitación</h1>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Create" method="post" class="col-md-6">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Código</label>
        <input asp-for="Codigo" class="form-control" placeholder="Ej: LIC-2026-001" />
    </div>
    <div class="mb-3">
        <label class="form-label">Título</label>
        <input asp-for="Titulo" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Fecha y hora de cierre</label>
        <input asp-for="FechaCierre" type="datetime-local" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Presupuesto estimado (CRC)</label>
        <input asp-for="PresupuestoEstimadoCRC" type="number" step="0.01" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Crear (queda en Borrador)</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>

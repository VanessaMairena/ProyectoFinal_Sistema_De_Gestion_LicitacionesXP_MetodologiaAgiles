@model ResultadoPaginado<LicitacionDto>
@{
    ViewData["Title"] = "Licitaciones";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Licitaciones</h1>
    <a asp-action="Create" class="btn btn-success">+ Nueva licitación</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="estado" class="form-select" onchange="this.form.submit()">
            <option value="">-- Todos los estados --</option>
            @foreach (EstadoLicitacion e in Enum.GetValues<EstadoLicitacion>())
            {
                <option value="@e" selected="@(ViewBag.Estado?.ToString() == e.ToString())">@e</option>
            }
        </select>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>Título</th>
            <th>Estado</th>
            <th>Cierre</th>
            <th>Presupuesto (CRC)</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var l in Model.Items)
        {
            <tr>
                <td>@l.Codigo</td>
                <td>@l.Titulo</td>
                <td><span class="badge text-bg-info">@l.Estado</span></td>
                <td>@l.FechaCierre.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                <td>@l.PresupuestoEstimadoCRC.ToString("N2")</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@l.Id" class="btn btn-sm btn-outline-primary">Ver</a>
                    <a asp-action="Edit" asp-route-id="@l.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    <a asp-action="Delete" asp-route-id="@l.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
        }
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No hay licitaciones registradas.</td></tr>
        }
    </tbody>
</table>

@if (Model.TotalPaginas > 1)
{
    <nav>
        <ul class="pagination">
            @for (var i = 1; i <= Model.TotalPaginas; i++)
            {
                <li class="page-item @(i == Model.Pagina ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-estado="@ViewBag.Estado">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@model CrearTipoCambioRequest
@{
    ViewData["Title"] = "Nuevo tipo de cambio";
}

<h1>Nuevo tipo de cambio</h1>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Create" method="post" class="col-md-6">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Colones (₡) por 1 dólar</label>
        <input asp-for="CRCporUSD" type="number" step="0.0001" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Fecha de vigencia</label>
        <input asp-for="FechaVigencia" type="date" class="form-control" />
    </div>
    <div class="alert alert-warning">
        Al guardar, este tipo de cambio quedará activo automáticamente y el anterior se desactivará.
    </div>
    <button type="submit" class="btn btn-primary">Guardar y activar</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>

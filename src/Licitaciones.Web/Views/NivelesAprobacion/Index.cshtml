@model IReadOnlyList<NivelAprobacionDto>
@{
    ViewData["Title"] = "Niveles de Aprobación";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Niveles de Aprobación</h1>
    <a asp-action="Create" class="btn btn-success">+ Nuevo nivel</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Monto mínimo (CRC)</th>
            <th>Monto máximo (CRC)</th>
            <th>Aprobador</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var n in Model)
        {
            <tr>
                <td>@n.MontoMinimoCRC.ToString("N2")</td>
                <td>@(n.MontoMaximoCRC?.ToString("N2") ?? "Sin límite (rango abierto)")</td>
                <td>@n.Aprobador</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@n.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    <form asp-action="Delete" asp-route-id="@n.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
        @if (Model.Count == 0)
        {
            <tr><td colspan="4" class="text-center text-muted">No hay niveles de aprobación configurados.</td></tr>
        }
    </tbody>
</table>

<hr class="my-4" />

<h2>Consultar aprobador según monto</h2>
<form asp-action="Resolver" method="post" class="row g-2 col-md-6">
    @Html.AntiForgeryToken()
    <div class="col-auto">
        <input type="number" step="0.01" name="montoCRC" class="form-control" placeholder="Monto en CRC" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">Ver aprobador</button>
    </div>
</form>

@model CrearNivelAprobacionRequest
@{
    ViewData["Title"] = "Nuevo nivel de aprobación";
}

<h1>Nuevo nivel de aprobación</h1>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Create" method="post" class="col-md-6">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Monto mínimo (CRC)</label>
        <input asp-for="MontoMinimoCRC" type="number" step="0.01" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Monto máximo (CRC)</label>
        <input asp-for="MontoMaximoCRC" type="number" step="0.01" class="form-control" />
        <div class="form-text">Dejalo vacío para que este sea el rango abierto (sin límite superior).</div>
    </div>
    <div class="mb-3">
        <label class="form-label">Aprobador</label>
        <input asp-for="Aprobador" class="form-control" placeholder="Ej: Gerencia Financiera" />
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-link">Cancelar</a>
</form>

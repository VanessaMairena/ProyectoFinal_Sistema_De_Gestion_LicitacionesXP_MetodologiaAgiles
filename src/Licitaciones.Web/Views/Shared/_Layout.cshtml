<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Sistema de Gestión de Licitaciones</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-md navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Gestión de Licitaciones</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Licitaciones" asp-action="Index">Licitaciones</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Proveedores" asp-action="Index">Proveedores</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="NivelesAprobacion" asp-action="Index">Niveles de Aprobación</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="TipoCambio" asp-action="Index">Tipo de Cambio</a></li>
                    <li class="nav-item"><a class="nav-link" href="/swagger" target="_blank">API (Swagger)</a></li>
                </ul>
                <button id="toggleTema" class="btn btn-outline-light btn-sm" type="button">🌙 Modo oscuro</button>
            </div>
        </div>
    </nav>

    <div class="container">
        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success">@TempData["Mensaje"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const boton = document.getElementById('toggleTema');
        const raiz = document.documentElement;
        const temaGuardado = localStorage.getItem('tema');
        if (temaGuardado === 'oscuro') {
            raiz.setAttribute('data-bs-theme', 'dark');
            boton.textContent = '☀️ Modo claro';
        }
        boton.addEventListener('click', () => {
            const esOscuro = raiz.getAttribute('data-bs-theme') === 'dark';
            raiz.setAttribute('data-bs-theme', esOscuro ? 'light' : 'dark');
            boton.textContent = esOscuro ? '🌙 Modo oscuro' : '☀️ Modo claro';
            localStorage.setItem('tema', esOscuro ? 'claro' : 'oscuro');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

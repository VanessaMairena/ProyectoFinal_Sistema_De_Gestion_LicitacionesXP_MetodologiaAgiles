@model ResultadoPaginado<ProveedorDto>
@{
    ViewData["Title"] = "Proveedores";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Proveedores</h1>
    <a asp-action="Create" class="btn btn-success">+ Nuevo proveedor</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="filtro" value="@ViewBag.Filtro" class="form-control" placeholder="Buscar por nombre..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Actualizado</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Items)
        {
            <tr>
                <td>@p.Nombre</td>
                <td>@p.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
        }
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="3" class="text-center text-muted">No hay proveedores registrados.</td></tr>
        }
    </tbody>
</table>

@if (Model.TotalPaginas > 1)
{
    <nav>
        <ul class="pagination">
            @for (var i = 1; i <= Model.TotalPaginas; i++)
            {
                <li class="page-item @(i == Model.Pagina ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-filtro="@ViewBag.Filtro">@i</a>
                </li>
            }
        </ul>
    </nav>
}
